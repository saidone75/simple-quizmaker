<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-teacher-theme-preference" author="quizmaker">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <and>
                <tableExists tableName="teachers"/>
                <not>
                    <columnExists tableName="teachers" columnName="theme_preference"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="teachers">
            <column name="theme_preference" type="VARCHAR(16)"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="teachers" columnName="theme_preference"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
