<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004" author="quizmaker">
        <comment>Create students and quiz submissions tables</comment>

        <createTable tableName="students">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="full_name" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="login_keyword" type="VARCHAR(4)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_students_login_keyword"/>
            </column>
        </createTable>

        <createTable tableName="quiz_submissions">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="student_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="quiz_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="answers" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="score" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="total_questions" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="unlocked" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="submitted_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="quiz_submissions"
                                 baseColumnNames="student_id"
                                 referencedTableName="students"
                                 referencedColumnNames="id"
                                 constraintName="fk_quiz_submissions_student"/>

        <addForeignKeyConstraint baseTableName="quiz_submissions"
                                 baseColumnNames="quiz_id"
                                 referencedTableName="quizzes"
                                 referencedColumnNames="id"
                                 constraintName="fk_quiz_submissions_quiz"/>

        <addUniqueConstraint tableName="quiz_submissions"
                             columnNames="student_id,quiz_id"
                             constraintName="uk_submission_student_quiz"/>

        <rollback>
            <dropTable tableName="quiz_submissions"/>
            <dropTable tableName="students"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
