<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-quiz-archive-flag-h2-postgres" author="quizmaker" dbms="h2,postgresql">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not>
                <columnExists tableName="quizzes" columnName="archived"/>
            </not>
        </preConditions>

        <addColumn tableName="quizzes">
            <column name="archived" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="quizzes" columnName="archived"/>
        </rollback>
    </changeSet>

    <changeSet id="002-quiz-archive-flag-sqlite" author="quizmaker" dbms="sqlite">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not>
                <columnExists tableName="quizzes" columnName="archived"/>
            </not>
        </preConditions>

        <addColumn tableName="quizzes">
            <column name="archived" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <rollback>
            <dropColumn tableName="quizzes" columnName="archived"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
