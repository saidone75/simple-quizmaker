<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001" author="quizmaker">
        <comment>Create quizzes table</comment>

        <createTable tableName="quizzes">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="emoji" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="questions" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="quizzes"/>
        </rollback>
    </changeSet>

    <changeSet id="002" author="quizmaker">
        <comment>Insert sample quiz - La Preistoria</comment>

        <insert tableName="quizzes">
            <column name="id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="title" value="La Preistoria"/>
            <column name="emoji" value="🦕"/>
            <column name="questions" value='[{"text":"Come si chiama il periodo in cui gli esseri umani usavano strumenti di pietra?","emoji":"🪨","options":["Età del Bronzo","Età della Pietra","Età del Ferro","Età del Rame"],"answer":1,"feedback":"Esatto! L''Età della Pietra è il periodo più lungo della preistoria."},{"text":"Quale fu la scoperta più importante dell''uomo preistorico?","emoji":"🔥","options":["La ruota","Il fuoco","L''arco","L''agricoltura"],"answer":1,"feedback":"Corretto! Il controllo del fuoco cambiò per sempre la vita degli esseri umani."},{"text":"Come si chiama il grande animale preistorico simile all''elefante con lungo pelo?","emoji":"🦣","options":["Mastodonte","Mammut lanoso","Megaterio","Diprotodon"],"answer":1,"feedback":"Giusto! Il mammut lanoso era perfettamente adattato al freddo dell''era glaciale."}]'/>
            <column name="created_at" valueDate="2024-01-01T00:00:00"/>
        </insert>

        <rollback>
            <delete tableName="quizzes">
                <where>id = '11111111-1111-1111-1111-111111111111'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
